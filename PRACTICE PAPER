#include <stdio.h>
#include <stdlib.h>

// Node structure
struct Node {
    int data;
    struct Node* prev;
    struct Node* next;
};

struct Node* head = NULL;

// Insert at end
void InsertEnd(int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;
    newNode->next = NULL;

    if (head == NULL) {
        newNode->prev = NULL;
        head = newNode;
        return;
    }

    struct Node* temp = head;
    while (temp->next != NULL) temp = temp->next;

    temp->next = newNode;
    newNode->prev = temp;
}

// Forward traverse
void Traverse() {
    struct Node* temp = head;
    if (!temp) { printf("List is empty\n"); return; }
    printf("Forward: ");
    while (temp) {
        printf("%d ", temp->data);
        temp = temp->next;
    }
    printf("\n");
}

// Reverse traverse
void ReverseTraverse() {
    struct Node* temp = head;
    if (!temp) { printf("List is empty\n"); return; }
    while (temp->next) temp = temp->next;
   
    printf("Reverse: ");
    while (temp) {
        printf("%d ", temp->data);
        temp = temp->prev;
    }
    printf("\n");
}

int main() {
    InsertEnd(10);
    InsertEnd(20);
    InsertEnd(30);
    Traverse();
    ReverseTraverse();
    return 0;
}
